  "problem_spec": {
    "summary": "Compute the permanent of a 4×4 matrix whose entries are given by a linear formula modulo 7, then reduce the result modulo 1000.",
    "object(s)": [
      {
        "name": "M",
        "type": "matrix",
        "role": "given",
        "dependency": "dependent"
      },
      {
        "name": "perm(M)",
        "type": "integer",
        "role": "output",
        "dependency": "dependent"
      }
    ],
    "givens": [
      "M is 4×4 with indices i,j \\in {1,2,3,4}.",
      "M_{ij} = (i + 2j) mod 7, interpreted in {0,1,2,3,4,5,6}."
    ],
    "ask": [
      "Compute perm(M) mod 1000."
    ]
  },
  "answer_spec": {
    "type": "integer_mod_m",
    "normalization": "mod_m",
    "modulus": 1000
  },
  "family_structure": {
    "parameter(s)": [
      {
        "name": "n",
        "type": "int",
        "domain": 4,
        "purpose": "matrix size"
      },
      {
        "name": "entry_modulus",
        "type": "int",
        "domain": 7,
        "purpose": "modulus defining entries"
      },
      {
        "name": "alpha",
        "type": "int",
        "domain": 1,
        "purpose": "coefficient of i in entry definition"
      },
      {
        "name": "beta",
        "type": "int",
        "domain": 2,
        "purpose": "coefficient of j in entry definition"
      },
      {
        "name": "output_modulus",
        "type": "int",
        "domain": 1000,
        "purpose": "final reduction modulus"
      }
    ],
    "invariant(s)": [
      {
        "name": "deterministic_entry_rule",
        "depends_on": [
          "n",
          "entry_modulus",
          "alpha",
          "beta"
        ],
        "statement": "For fixed parameters, each entry is uniquely M_{ij}=(alpha \\cdot i+beta \\cdot j) mod entry_modulus."
      },
      {
        "name": "permanent_definition",
        "depends_on": [
          "M"
        ],
        "statement": "perm(M)=Σ_{\\pi\\inS_n} Π_{i=1}^n M_{i,\\pi(i)}."
      },
      {
        "name": "ryser_formula",
        "depends_on": [
          "M"
        ],
        "statement": "perm(M)=Σ_{S⊆[n]} (-1)^{n-|S|} Π_{i=1}^n (Σ_{j\\inS} M_{ij})."
      }
    ]
  },
