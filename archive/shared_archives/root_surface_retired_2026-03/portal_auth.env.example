# Copy this file to "portal_auth.env" in the project root and fill values.
# run_portal.ps1 auto-loads portal_auth.env in prod if present.

ATHENA_AUTH_PROVIDER=github
ATHENA_GUEST_LOGIN_ENABLED=1
ATHENA_GUEST_PROMPT_LIMIT=0
ATHENA_GITHUB_CLIENT_ID=your-github-client-id
ATHENA_GITHUB_CLIENT_SECRET=your-github-client-secret
ATHENA_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ATHENA_GOOGLE_CLIENT_SECRET=your-google-client-secret
ATHENA_PORTAL_SESSION_SECRET=replace-with-long-random-string
ATHENA_AUTH_REDIRECT_URI=https://portal.neohmlabs.com/AEN5/auth/callback
ATHENA_CLOUDFLARE_TUNNEL_NAME=your-cloudflare-tunnel-name
