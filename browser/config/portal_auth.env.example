# Copy this file to "portal_auth.env" in this same browser/config folder and fill values.
# run_portal.ps1 and browser\run_browser.ps1 auto-load browser/config/portal_auth.env in prod if present.
# MiamiOH pilot today only needs Google configured. Canvas env vars can stay blank unless live LMS OAuth is being turned on.

ATHENA_AUTH_PROVIDER=google
ATHENA_DEFAULT_INSTITUTION=miamioh
ATHENA_GUEST_LOGIN_ENABLED=1
ATHENA_GUEST_PROMPT_LIMIT=0
ATHENA_GOOGLE_CLIENT_ID=
ATHENA_GOOGLE_CLIENT_SECRET=
ATHENA_GITHUB_CLIENT_ID=
ATHENA_GITHUB_CLIENT_SECRET=
# Optional future Canvas OAuth for MiamiOH:
ATHENA_CANVAS_MIAMIOH_CLIENT_ID=
ATHENA_CANVAS_MIAMIOH_CLIENT_SECRET=
ATHENA_CANVAS_MIAMIOH_REDIRECT_URI=https://portal.neohmlabs.com/AEN5/auth/callback
ATHENA_PORTAL_SESSION_SECRET=
ATHENA_AUTH_REDIRECT_URI=https://portal.neohmlabs.com/AEN5/auth/callback
ATHENA_CLOUDFLARE_TUNNEL_NAME=
